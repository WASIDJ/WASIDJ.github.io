      <title>ECharts with CSV Example</title>
      <link href="/archives/f0ccffe4.html"/>
      <url>/archives/f0ccffe4.html</url>
      
        <content type="html"><![CDATA[<h2 id="ECharts-with-CSV-Example"><a href="#ECharts-with-CSV-Example" class="headerlink" title="ECharts with CSV Example"></a>ECharts with CSV Example</h2><div id="echarts9570" style="width: 85%;height: height=400pxpx;margin: 0 auto"></div><script src="https://cdn.jsdelivr.net/npm/echarts@5.3.0/dist/echarts.min.js"></script><script type="text/javascript">        // 基于准备好的dom，初始化echarts实例        var myChart = echarts.init(document.getElementById('echarts9570'));        // 指定图表的配置项和数据        var option = <script>    fetch('/data.csv')        .then(response => response.text())        .then(csvData => {            const parsedData = Papa.parse(csvData, {                header: true,                skipEmptyLines: true            }).data;            const categories = parsedData.map(item => item['Category']);            const values = parsedData.map(item => parseFloat(item['Value']));            const option = {                title: {                    text: 'ECharts Example'                },                tooltip: {},                xAxis: {                    type: 'category',                    data: categories                },                yAxis: {                    type: 'value'                },                series: [{                    name: 'Value',                    type: 'bar',                    data: values                }]            };            echarts.init(document.getElementById('echarts-content')).setOption(option);        })        .catch(error => {            console.error('Error loading CSV file:', error);        });</script>        // 使用刚指定的配置项和数据显示图表。        myChart.setOption(option);</script>]]></content>
      
      
      
